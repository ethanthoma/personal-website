#!/bin/bash

declare -a SOURCE_URLS=(
	"https://unpkg.com/htmx.org@1.9.3/dist/htmx.min.js"
)

# Define the target directory where the file will be saved
TARGET_DIR="../vendors"

mkdir -p "$TARGET_DIR"

# Loop through each URL in the array
for url in "${SOURCE_URLS[@]}"; do
  filename=$(basename "$url")
  curl -L "$url" -o "$TARGET_DIR/$filename"

  # Verify if the download was successful
  if [ $? -eq 0 ]; then
    echo "Installed $filename from $url successfully"
  else
    echo "Failed to download$filename from $url"
  fi
done
