package components

type Footer struct{}

templ (p Footer) View() {
	<footer class="pt-s border-t-content border-t-2 mt-xl">
		<p class="text-wrap text-center">
			&copy;2024 Ethan Thoma. All rights reserved.
		</p>
		<button data-on-click="$$get('/events')">Get Backend State</button>
		<div id="time"></div>
	</footer>
}
