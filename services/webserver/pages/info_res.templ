templ (p InfoRes) View() {
	@layouts.Base{
		Pages:       p.Pages,
		PageCurrent: "resources",
		Title:       "Ethan Thoma / Resources",
	}.View() {
		<article class="row-start-1 col-[2/-2]">
			<header>
				<h1 class="font-bold leading-none text-l text-content/70">Resources</h1>
			</header>
			<p class="font-sans mt-m text-m text-content/40">
				Machine learning papers and programming language theory links that I've read or are to-be-read.
			</p>
			<h2 class="font-medium mt-xl text-m text-content/40">Machine learning</h2>
			<ol class="flex flex-col mt-s">
				for _, item := range items_ml {
					@resourceRow(item)
				}
			</ol>
			<h2 class="font-medium mt-xl text-m text-content/40">Programming language theory</h2>
			<ol class="flex flex-col mt-s">
				for _, item := range items_plt {
					@resourceRow(item)
				}
			</ol>
		</article>
	}
}

templ resourceRow(item Item) {
	{{ year := item.DisplayYear() }}
	<li>
		<a href={ templ.URL(item.URL) } class="flex items-baseline group py-3xs">
			<span class="flex relative flex-1 items-baseline min-w-0 gap-xs">
				if year > 0 {
					<span class="absolute inset-x-0 h-px top-[calc(0.5lh-0.5px)] bg-black/20"></span>
				}
				<span class="relative flex-1 min-w-0">
					<span
						class={
							"bg-base box-decoration-clone pl-[2ch] [text-indent:-2ch] pr-2xs-xs group-hover:text-blue group-hover:underline",
							templ.KV("text-content/60", !item.Read),
						}
					>{ item.Title }</span>
				</span>
				if year > 0 {
					<span class="relative tabular-nums shrink-0 bg-base box-decoration-clone pl-2xs-xs text-content/40">{ fmt.Sprintf("%d", year) }</span>
				}
			</span>
		</a>
	</li>
}
