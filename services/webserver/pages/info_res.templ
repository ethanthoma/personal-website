package pages

import (
	"fmt"
	"personal-website/services/webserver/layouts"
	"regexp"
	"strconv"
	"strings"
)

type InfoRes struct {
	Pages []string
}

type Item struct {
	Title string
	URL   string
	Year  int
	Read  bool
}

var yearURLRegex = regexp.MustCompile(`/(19|20)\d{2}[/.]`)

func (i Item) DisplayYear() int {
	if i.Year > 0 {
		return i.Year
	}
	if idx := strings.Index(i.URL, "/abs/"); idx >= 0 {
		rest := i.URL[idx+5:]
		if len(rest) >= 4 {
			if yy, err := strconv.Atoi(rest[:2]); err == nil && yy >= 7 && yy <= 50 {
				return 2000 + yy
			}
		}
	}
	if m := yearURLRegex.FindString(i.URL); m != "" {
		if y, err := strconv.Atoi(m[1:5]); err == nil {
			return y
		}
	}
	return 0
}

